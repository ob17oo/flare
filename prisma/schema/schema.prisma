generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum USER_ROLE {
  USER
  ADMIN
  MODERATOR
}

enum STATUS {
  PENDING
  CANCELLED
  SUCCESS
  PROCESSING
}

enum PRODUCT_EDITION {
  Lite
  Standard
  Deluxe
  Essentials
  Extra
  Premium
  Core
  Ultimate
  Arcade
  Nitro
  DLC
  NSO
  PLUS
}

enum PRODUCT_TYPE {
  GAME
  WALLET
  SERVICE_PLANS
  BANNER
}

