model User {
  id        String    @id @default(cuid())
  login     String
  email     String    @unique
  password  String
  image_url String    @default("/static/default/default-user.svg")
  discount  Int       @default(1) @db.SmallInt
  maxUserDiscount Int @default(20) 
  balance   Int       @default(0)
  spent Int @default(0)
  role      USER_ROLE @default(USER)
  orders    Order[]
  deposits  Deposit[]
  tickets          SupportTicket[] @relation("UserTickets")
  moderatedTickets SupportTicket[] @relation("ModeratorTickets")
  isBanned  Boolean   @default(false)

  @@index([email])
}