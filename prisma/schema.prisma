// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum USER_ROLE {
  USER
  ADMIN
  MODERATOR
}
enum STATUS {
  PENDING
  CANCELLED
  SUCCESS
  PROCESSING
}

enum PRODUCT_EDITION {
  Lite
  Standard
  Essentials
  Deluxe
  Extra
  Premium
  Core
  Ultimate
  Arcade
  Nitro
  DLC
}

enum PRODUCT_TYPE {
  GAME
  WALLET
  SERVICE_PLANS
  BANNER
}

model User {
  id String @id @default(cuid())
  login String
  email String @unique
  password String
  image_url String @default("/static/default/default-user.svg")
  discount Int @default(1)
  balance Int @default(0)
  role USER_ROLE @default(USER)
}

model Product {
  id Int @id @default(autoincrement())
  title String
  description String?
  image_url String @default("/static/default/default-product.png")
  productType PRODUCT_TYPE @default(GAME)
  productEdition PRODUCT_EDITION @default(Standard)
  price Int @default(0)

  stock Int @default(0)
  rating Float @default(0.0)
  isActive Boolean @default(true) 

  game Game?
  servicePlans ServicePlans?

  @@index([productType, isActive])
  @@index([price])
  @@index([rating])
}

model Launcher {
  id Int @id @default(autoincrement())
  title String @default("Flare")
  image_url String @default("/static/default/default-launcher.svg")
  games Game[]
}

model Game {
  id Int @id @default(autoincrement())
  productId Int @unique
  product Product @relation(fields: [productId], references: [id])
  launcherId Int
  launcher Launcher @relation(fields: [launcherId], references: [id])

  genre String
  
}

model ServicePlatform {
  id Int @id @default(autoincrement())
  title String @unique
  description String
  image_url String @default("/static/default/default-service.svg")
  category String @default("Gaming")

  servicePlans ServicePlans[]
}

model ServicePlans {
  id Int @id @default(autoincrement())
  productId Int @unique
  product Product @relation(fields: [productId], references: [id])
  subTitle String
  duration Int

  serviceId Int
  servicePlatform ServicePlatform @relation(fields: [serviceId], references: [id])
}