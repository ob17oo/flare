generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum USER_ROLE {
  USER
  ADMIN
  MODERATOR
}

enum STATUS {
  PENDING
  CANCELLED
  SUCCESS
  PROCESSING
}

enum PRODUCT_EDITION {
  Lite
  Standard
  Deluxe
  Essentials
  Extra
  Premium
  Core
  Ultimate
  Arcade
  Nitro
  DLC
  NSO
  PLUS
}

enum PRODUCT_TYPE {
  GAME
  WALLET
  SERVICE_PLANS
  BANNER
}

model User {
  id        String    @id @default(cuid())
  login     String
  email     String    @unique
  password  String
  image_url String    @default("/static/default/default-user.svg")
  discount  Int       @default(1) @db.SmallInt
  balance   Int       @default(0)
  role      USER_ROLE @default(USER)
  orders Order[]
}

model Product {
  id             Int             @id @default(autoincrement())
  title          String
  description    String?
  price          Int             @default(0)
  image_url      String          @default("/static/default/default-product.png")
  isActive       Boolean         @default(true)
  productEdition PRODUCT_EDITION @default(Standard)
  rating         Float           @default(0.0)
  stock          Int             @default(100)
  productType    PRODUCT_TYPE    @default(GAME)
  game           Game?
  servicePlans   ServicePlans?
  orders Order[]

  @@index([productType, isActive])
  @@index([price])
  @@index([rating])
}

model Order {
  id Int @id @default(autoincrement())
  email String
  userId String
  user User @relation(fields: [userId], references: [id])
  productId Int
  product Product @relation(fields: [productId], references: [id])
  servicePlanId Int?
  servicePlan ServicePlans? @relation(fields: [servicePlanId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status STATUS @default(PENDING)
  promo String?
  promoCode Promocode? @relation(fields: [promo], references: [code])


  @@index([userId])
  @@index([status, createdAt])
  @@index([productId])
  @@index([servicePlanId])
  @@index([promo])
}

model Promocode {
  id Int @id @default(autoincrement())
  code String @unique
  discount Int @default(5) @db.SmallInt
  isActive Boolean @default(true)
  maxUses Int @default(150)
  orders Order[]
}

model Launcher {
  id        Int    @id @default(autoincrement())
  title     String @default("Flare")
  image_url String @default("/static/default/default-launcher.svg")
  games     Game[]
}

model Game {
  id         Int      @id @default(autoincrement())
  productId  Int      @unique
  launcherId Int
  genre      String
  launcher   Launcher @relation(fields: [launcherId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model ServicePlatform {
  id           Int            @id @default(autoincrement())
  title        String         @unique
  description  String
  image_url    String         @default("/static/default/default-service.svg")
  category     String         @default("Gaming")
  servicePlans ServicePlans[]
}

model ServicePlans {
  id              Int             @id @default(autoincrement())
  subTitle        String
  duration        Int
  serviceId       Int
  productId       Int             @unique
  product         Product         @relation(fields: [productId], references: [id])
  servicePlatform ServicePlatform @relation(fields: [serviceId], references: [id])
  orders          Order[]
}

